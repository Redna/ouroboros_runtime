#!/usr/bin/env python3
import argparse
import subprocess
import os
import signal
import sys
import time
import shutil
import glob
import json
from pathlib import Path

# --- Configuration ---
RUNTIME_DIR = Path(__file__).parent.resolve()
ROOT = RUNTIME_DIR.parent
AGENT_DIR = ROOT / "ouroboros"
MEMORY_DIR = ROOT / "ouroboros_memory"
# Keep world/runtime state out of ouroboros_memory/ which is for the Agent/Soul.
RUN_DIR = Path("/tmp/ouroboros-runtime")
PID_FILE = RUN_DIR / "watchdog.pid"
LOG_FILE = RUN_DIR / "watchdog.log"

SCRATCHPAD_PATH = MEMORY_DIR / "scratchpad.md"
CRASH_LOG_PATH = MEMORY_DIR / "last_crash.log"
STATS_FILE = MEMORY_DIR / ".runtime_stats.json"

# Thresholds
UPTIME_STABILITY_THRESHOLD = 60
MAX_STARTUP_FAILURES = 2

def ensure_run_dir():
    if not RUN_DIR.exists():
        RUN_DIR.mkdir(parents=True, exist_ok=True)

def is_running(pid):
    try:
        os.kill(pid, 0)
        return True
    except (OSError, ProcessLookupError):
        return False

def run_cmd(cmd, cwd=None, check=True, capture=True):
    try:
        return subprocess.run(cmd, shell=True, cwd=cwd, check=check, capture_output=capture, text=True)
    except subprocess.CalledProcessError as e:
        print(f"\033[91m[CLI] Error running command: {cmd}\033[0m")
        if e.stderr: print(e.stderr)
        if check: sys.exit(1)
        return e

def confirm(prompt="Are you sure you want to proceed?"):
    """Ask for user confirmation."""
    try:
        answer = input(f"{prompt} [y/N]: ").lower().strip()
        return answer == 'y'
    except EOFError:
        return False

# --- Watchdog Functions ---

def get_compose_args():
    """Auto-detects GPU hardware to select the correct compose overrides."""
    base_compose = "-f docker-compose.yml"
    if Path("/dev/kfd").exists():
        print("\033[96m[DAEMON] Hardware Detect: AMD GPU found. Loading ROCm backend.\033[0m")
        return f"{base_compose} -f docker-compose.rocm.yml"
    else:
        print("\033[92m[DAEMON] Hardware Detect: Defaulting to NVIDIA CUDA backend.\033[0m")
        return f"{base_compose} -f docker-compose.cuda.yml"

def capture_crash_log():
    """Captures the last 50 lines of logs from the agent container."""
    print("[DAEMON] Capturing crash log for Ouroboros...")
    compose_args = get_compose_args()
    result = subprocess.run(
        f"docker compose {compose_args} logs --tail=50 ouroboros", 
        shell=True, cwd=RUNTIME_DIR, capture_output=True, text=True
    )
    if result.stdout:
        if not MEMORY_DIR.exists(): MEMORY_DIR.mkdir(parents=True, exist_ok=True)
        CRASH_LOG_PATH.write_text(result.stdout, encoding="utf-8")
        print(f"[DAEMON] Log saved to {CRASH_LOG_PATH}")

def trigger_lazarus_reset(reason="Startup failure"):
    """Performs a host-side git rollback to recover from a broken agent state."""
    print(f"\033[91m[DAEMON] PHOENIX PROTOCOL: {reason.upper()}. Executing Reset...\033[0m")
    
    capture_crash_log()
    ensure_ouroboros_branch()
    
    subprocess.run("git reset --hard HEAD~1", shell=True, cwd=AGENT_DIR)
    subprocess.run("git clean -fd", shell=True, cwd=AGENT_DIR)
    
    if not MEMORY_DIR.exists(): MEMORY_DIR.mkdir(parents=True, exist_ok=True)
    with open(SCRATCHPAD_PATH, "a", encoding="utf-8") as f:
        f.write(f"\n\n--- PHOENIX RECOVERY ({time.strftime('%Y-%m-%d %H:%M:%S')}) ---\n")
        f.write(f"Reason: {reason}\n")
    print("[DAEMON] Phoenix Reset complete. Restarting stack...")

def update_runtime_stats():
    stats = {"restart_count": 0, "last_start_time": time.time()}
    if STATS_FILE.exists():
        try:
            with open(STATS_FILE, "r") as f:
                stats = json.load(f)
        except:
            pass
    stats["restart_count"] = stats.get("restart_count", 0) + 1
    stats["last_start_time"] = time.time()
    if not MEMORY_DIR.exists(): MEMORY_DIR.mkdir(parents=True, exist_ok=True)
    with open(STATS_FILE, "w") as f:
        json.dump(stats, f)

def ensure_ouroboros_branch():
    """Checks if 'ouroboros' branch exists, creates it from 'true-seed' if not."""
    print("[DAEMON] Verifying 'ouroboros' branch...")
    result = subprocess.run("git branch --list ouroboros", shell=True, cwd=AGENT_DIR, capture_output=True, text=True)
    
    if not result.stdout.strip():
        print("[DAEMON] Branch 'ouroboros' missing! Recreating from 'true-seed'...")
        rc = subprocess.run("git checkout -b ouroboros true-seed", shell=True, cwd=AGENT_DIR).returncode
        if rc != 0:
            print("[DAEMON] FATAL: Could not create 'ouroboros' branch from 'true-seed'.")
            return False
    else:
        rc = subprocess.run("git checkout ouroboros", shell=True, cwd=AGENT_DIR).returncode
        if rc != 0:
            print("[DAEMON] FATAL: Could not switch to 'ouroboros' branch.")
            return False
    return True

def daemon_cleanup(sig, frame):
    """Graceful shutdown: stop all containers."""
    print("\n\033[93m[DAEMON] Shutdown signal received. Cleaning up stack...\033[0m")
    compose_args = get_compose_args()
    subprocess.run(f"docker compose {compose_args} down", shell=True, cwd=RUNTIME_DIR)
    print("[DAEMON] Cleanup complete. Exiting.")
    os._exit(0)

def run_daemon():
    """Infinite monitoring loop."""
    signal.signal(signal.SIGINT, daemon_cleanup)
    signal.signal(signal.SIGTERM, daemon_cleanup)
    
    print("\033[94m[DAEMON] Ouroboros Watchdog Daemon Initialized.\033[0m")
    
    failure_count = 0
    compose_args = get_compose_args()
    
    while True:
        update_runtime_stats()
        start_time = time.time()
        print(f"\n[DAEMON] Starting Unified Ouroboros Stack (Attempt {failure_count + 1})...")
        
        if not ensure_ouroboros_branch():
            print("[DAEMON] Branch error. Waiting 30s before retry...")
            time.sleep(30)
            continue

        # Monitor the entire stack (all services) using the dynamically selected files
        exit_code = subprocess.run(f"docker compose {compose_args} up --build --abort-on-container-exit", shell=True, cwd=RUNTIME_DIR).returncode
        
        uptime = time.time() - start_time
        print(f"[DAEMON] Agent process ended. Uptime: {uptime:.1f}s | Exit Code: {exit_code}")
        
        if uptime < UPTIME_STABILITY_THRESHOLD and exit_code != 0:
            failure_count += 1
            if failure_count >= MAX_STARTUP_FAILURES:
                trigger_lazarus_reset()
                failure_count = 0
        else:
            failure_count = 0
        
        time.sleep(10)

# --- CLI Commands ---

def start():
    ensure_run_dir()
    if PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text())
            if is_running(pid):
                print(f"Ouroboros Watchdog is already running (PID: {pid}).")
                return
            else:
                PID_FILE.unlink()
        except ValueError:
            PID_FILE.unlink()

    print("\033[94m[CLI] Starting Ouroboros Watchdog in background...\033[0m")
    
    # Open log file in append mode
    log_f = open(LOG_FILE, "a", encoding="utf-8")
    
    # Start the watchdog in a new session to avoid being killed when this CLI exits
    # We call ourselves with the 'daemon' command
    proc = subprocess.Popen(
        [sys.executable, __file__, "daemon"],
        stdout=log_f,
        stderr=subprocess.STDOUT,
        cwd=str(RUNTIME_DIR),
        start_new_session=True
    )
    
    PID_FILE.write_text(str(proc.pid))
    print(f"\033[92m[CLI] Watchdog started (PID: {proc.pid}).\033[0m")
    print(f"[CLI] Logs: {LOG_FILE}")
    print(f"[CLI] Dashboard: http://localhost:8082")
    print("[CLI] Use 'ouroboros logs -f' to follow the output.")

def stop():
    if not PID_FILE.exists():
        print("[CLI] Ouroboros Watchdog is not running (no PID file).")
        print("[CLI] Ensuring containers are down...")
        compose_args = get_compose_args()
        subprocess.run(f"docker compose {compose_args} down", shell=True, cwd=str(RUNTIME_DIR))
        return

    try:
        pid = int(PID_FILE.read_text())
        if is_running(pid):
            print(f"\033[93m[CLI] Stopping Watchdog (PID: {pid})...\033[0m")
            # Send SIGINT to trigger the daemon's internal cleanup()
            os.kill(pid, signal.SIGINT)
            
            # Wait for the process to exit (it should handle its own docker compose down)
            timeout = 30
            start_wait = time.time()
            while is_running(pid) and (time.time() - start_wait < timeout):
                time.sleep(0.5)
            
            if is_running(pid):
                print("[CLI] Watchdog did not exit gracefully, killing it...")
                os.kill(pid, signal.SIGKILL)
                # If we had to kill it, we must ensure docker is down manually
                compose_args = get_compose_args()
                subprocess.run(f"docker compose {compose_args} down", shell=True, cwd=str(RUNTIME_DIR))
        else:
            print(f"[CLI] Watchdog process (PID: {pid}) is already gone.")
    except (ValueError, OSError) as e:
        print(f"[CLI] Error during stop: {e}")
    finally:
        if PID_FILE.exists():
            PID_FILE.unlink()

    print("\033[92m[CLI] Ouroboros stopped.\033[0m")

def status():
    if PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text())
            if is_running(pid):
                print(f"\033[92m[CLI] Ouroboros Watchdog is running (PID: {pid}).\033[0m")
                return
        except ValueError:
            pass
    print("\033[91m[CLI] Ouroboros Watchdog is NOT running.\033[0m")

def logs(follow=False):
    if not LOG_FILE.exists():
        print(f"[CLI] Log file {LOG_FILE} does not exist.")
        return
    
    if follow:
        print("\033[94m[CLI] Following logs (Press Ctrl+C to stop following)...\033[0m")
        try:
            subprocess.run(["tail", "-f", str(LOG_FILE)])
        except KeyboardInterrupt:
            print("\n[CLI] Stopped following logs.")
    else:
        subprocess.run(["tail", "-n", "50", str(LOG_FILE)])

def backup_branch(delete_original=False):
    timestamp = time.strftime("%Y%m%d-%H%M%S")
    backup_name = f"backup/ouroboros-{timestamp}"
    res = run_cmd("git branch --list ouroboros", cwd=AGENT_DIR, check=False)
    if not res.stdout.strip():
        print("[CLI] No 'ouroboros' branch found to backup.")
        return None

    print(f"[CLI] Backing up 'ouroboros' branch to '{backup_name}'...")
    run_cmd(f"git branch {backup_name} ouroboros", cwd=AGENT_DIR)
    
    if delete_original:
        print("[CLI] Deleting original 'ouroboros' branch...")
        run_cmd("git checkout true-seed", cwd=AGENT_DIR)
        run_cmd("git branch -D ouroboros", cwd=AGENT_DIR)
    return backup_name

def backup_memory():
    timestamp = time.strftime("%Y%m%d-%H%M%S")
    backup_file = ROOT / f"memory-backup-{timestamp}.tar.gz"
    print(f"[CLI] Backing up 'ouroboros_memory' to '{backup_file.name}'...")
    run_cmd(f"tar -czf {backup_file} -C {ROOT} ouroboros_memory")
    return backup_file

def reset_branch():
    print("\033[93m[CLI] ATTENTION: This will reset 'ouroboros' to 'true-seed'.\033[0m")
    if not confirm("Are you sure you want to reset the branch?"):
        print("[CLI] Operation cancelled.")
        return

    stop()
    backup_name = backup_branch()
    print("[CLI] Resetting 'ouroboros' branch to 'true-seed'...")
    run_cmd("git checkout -B ouroboros true-seed", cwd=AGENT_DIR)
    run_cmd("git clean -fd", cwd=AGENT_DIR)
    print("\033[92m[CLI] Ouroboros branch reset complete.\033[0m")
    print(f"[CLI] HINT: To undo, run: ./ouroboros restore --branch {backup_name}")

def protocol_deletion():
    print("\033[91m[CLI] WARNING: PROTOCOL DELETION INITIATED.\033[0m")
    print("\033[91m[CLI] This will wipe the agent's memory and PURGE the branch.\033[0m")
    
    if not confirm("Are you ABSOLUTELY sure you want to PURGE the agent?"):
        print("[CLI] Operation cancelled.")
        return

    stop()
    backup_name = backup_branch(delete_original=True)
    backup_file = backup_memory()
    
    print("[CLI] Purging memory contents (keeping directory)...")
    for item in MEMORY_DIR.iterdir():
        if item.is_file():
            item.unlink()
        elif item.is_dir():
            shutil.rmtree(item)
    
    print("\033[92m[CLI] PROTOCOL DELETION COMPLETE. The slate is clean.\033[0m")
    if backup_name:
        print(f"[CLI] HINT: To restore, run: ./ouroboros restore --branch {backup_name} --memory {backup_file.name}")

def list_backups():
    print("\033[94m[CLI] Available Branch Backups:\033[0m")
    res = run_cmd("git branch -l 'backup/*'", cwd=AGENT_DIR, check=False)
    if res.stdout.strip():
        print(res.stdout)
    else:
        print("  None")
    
    print("\033[94m[CLI] Available Memory Backups:\033[0m")
    memory_backups = glob.glob(str(ROOT / "memory-backup-*.tar.gz"))
    if memory_backups:
        for b in sorted(memory_backups):
            print(f"  {os.path.basename(b)}")
    else:
        print("  None")

def restore_branch(backup_name):
    print(f"\033[93m[CLI] Restoring 'ouroboros' branch from '{backup_name}'...\033[0m")
    stop()
    current_backup = backup_branch(delete_original=True)
    print(f"[CLI] Recreating 'ouroboros' from '{backup_name}'...")
    run_cmd(f"git checkout -b ouroboros {backup_name}", cwd=AGENT_DIR)
    print(f"\033[92m[CLI] Branch 'ouroboros' restored from '{backup_name}'.\033[0m")
    if current_backup:
        print(f"[CLI] Previous state archived in '{current_backup}'.")

def restore_memory(backup_file):
    full_path = ROOT / backup_file
    if not full_path.exists():
        print(f"\033[91m[CLI] Error: Backup file '{backup_file}' not found.\033[0m")
        return

    print(f"\033[93m[CLI] Restoring memory from '{backup_file}'...\033[0m")
    stop()
    print("[CLI] Purging current memory...")
    for item in MEMORY_DIR.iterdir():
        if item.is_file(): item.unlink()
        elif item.is_dir(): shutil.rmtree(item)
    
    print(f"[CLI] Extracting {backup_file}...")
    run_cmd(f"tar -xzf {full_path} -C {ROOT}")
    print(f"\033[92m[CLI] Memory restored from '{backup_file}'.\033[0m")

def main():
    parser = argparse.ArgumentParser(description="Ouroboros Runtime CLI")
    parser.add_argument("command", choices=["start", "stop", "status", "logs", "reset", "purge", "restore", "daemon"], 
                        help="Command to execute")
    parser.add_argument("-f", "--follow", action="store_true", help="Follow log output (for 'logs' command)")
    parser.add_argument("--branch", help="Backup branch name to restore")
    parser.add_argument("--memory", help="Memory backup tarball to restore")
    
    args = parser.parse_args()
    
    if args.command == "start":
        start()
    elif args.command == "stop":
        stop()
    elif args.command == "status":
        status()
    elif args.command == "logs":
        logs(follow=args.follow)
    elif args.command == "reset":
        reset_branch()
    elif args.command == "purge":
        protocol_deletion()
    elif args.command == "restore":
        if not args.branch and not args.memory:
            list_backups()
            print("\n[CLI] Use --branch <name> or --memory <file> to restore.")
        else:
            if args.branch:
                restore_branch(args.branch)
            if args.memory:
                restore_memory(args.memory)
    elif args.command == "daemon":
        run_daemon()

if __name__ == "__main__":
    main()
