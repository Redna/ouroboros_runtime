# Ouroboros Runtime Environment Variables
# Copy this file to .env and configure as needed

# Telegram Bot Token (required for agent communication)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# The model file name you want the agent to use
OUROBOROS_MODEL=mistralai_Mistral-Small-3.2-24B-Instruct-2506-Q4_K_M.gguf

# Enable thinking tokens for reasoning mode (1=enabled, 0=disabled)
OUROBOROS_ENABLE_THINKING=0

# Define the max context window. This sets the llamacpp context and the agent's memory bounds.
# Common sizes: 16384, 32768, 65536
OUROBOROS_CONTEXT_WINDOW=65536

# Optional GitHub token
# GITHUB_TOKEN=your_github_token_here
