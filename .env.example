# ─── Infrastructure ──────────────────────────────────────────────────────────

# To use ROCm (AMD), uncomment the line below:
# COMPOSE_FILE=docker-compose.yml:docker-compose.rocm.yml

# Enable or disable local LLM (llamacpp container)
USE_LOCAL_LLM=true

# ─── Required ─────────────────────────────────────────────────────────────────

# vLLM server (OpenAI-compatible API)
VLLM_BASE_URL=http://llamacpp:8080/v1

# Model name exactly as registered in your vLLM server
OUROBOROS_MODEL=Qwen3.5-27B-Q4_K_M.gguf

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# GitHub personal access token (needs repo scope)
GITHUB_TOKEN=your_github_pat
GITHUB_USER=your_github_user
GITHUB_REPO=ouroboros

# Token budget (informational — no USD cost for local vLLM)
TOTAL_BUDGET=1000000

# ─── Optional ─────────────────────────────────────────────────────────────────

# API key for vLLM (leave as "token" if your server has no auth)
# VLLM_API_KEY=token

OUROBOROS_DRIVE_ROOT=/teamspace/studios/this_studio/core_files
OUROBOROS_REPO_DIR=/teamspace/studios/this_studio/ouroboros
OUROBOROS_BRANCH_DEV=ouroboros
OUROBOROS_BRANCH_STABLE=ouroboros-stable

OUROBOROS_ENABLE_THINKING=1
OUROBOROS_DISABLE_TOOLS=0
